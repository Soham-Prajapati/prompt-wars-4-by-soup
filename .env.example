# Google Gemini API key — required for the five AI panels.
#
# Get a free key at: https://aistudio.google.com/app/apikey
#
# Read server-side only, in src/lib/gemini.ts. It is never prefixed with
# NEXT_PUBLIC_, never returned in a response body, and never reaches the browser.
#
# Copy this file to .env.local and fill in the value. Without it the app still
# runs — the map, snapshot feed, computed routes and computed itinerary plans all
# work — but the AI panels return 503 AI_UNAVAILABLE and say so.
GEMINI_API_KEY=
